// PitchOS · prototype schema · single-tenant
//
// Sourced from SDD §12 with multi-tenancy stripped per the option-2 demo
// reshape. The full multi-tenant version is recoverable from the git
// tag `multitenant-snapshot`.
//
// What's gone (relative to the SDD): Organization, User, PartnerJudgment,
// Outcome models · all organizationId / ownerId scoping · QaSession /
// QaMessage models (Phase 6, deferred). Strategic IP that stays:
// PartnerRubric / PartnerProfile (versioned, seeded), the AnalysisRun
// stack (Report / SlideReview / Recommendation / InvestorObjection /
// AntiPatternDetection), per-claim sourceQuote citations.

generator client {
  provider = "prisma-client"
  output   = "../lib/prisma/generated"
}

datasource db {
  provider = "postgresql"
  // Connection URLs live in prisma.config.ts per Prisma 7 +
  // driver-adapter pattern. Runtime (lib/db.ts) reads DATABASE_URL
  // through PrismaPg; Migrate reads prisma.config.ts datasource.url
  // (DATABASE_URL_UNPOOLED on Neon, since pgbouncer transaction mode
  // does not support the prepared statements migrate deploy uses).
}

enum FundingStage {
  IDEA
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  GROWTH
  UNKNOWN
}

enum BusinessModel {
  SAAS
  MARKETPLACE
  CONSUMER
  ENTERPRISE
  FINTECH
  HEALTHCARE
  DEEP_TECH
  AI_INFRA
  SERVICES_ENABLED_SOFTWARE
  OTHER
}

enum InvestorArchetype {
  GENERALIST_SEED
  AI_NATIVE_FUND
  VERTICAL_THESIS
  STRATEGIC_INVESTOR
  ANGEL
  ACCELERATOR
}

enum AnalysisStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AnalysisStage {
  QUEUED
  VALIDATING_FILE
  EXTRACTING_FACTS
  REVIEWING_SLIDES
  SCORING_FUNDABILITY
  FINDING_OBJECTIONS
  BUILDING_DILIGENCE
  WRITING_MEMO
  BUILDING_ROADMAP
  FINALIZING_REPORT
  COMPLETED
  FAILED
}

enum MeetingLikelihood {
  STRONG_YES
  YES
  MAYBE
  NOT_YET
  NO
}

enum Priority {
  P0
  P1
  P2
  P3
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum EffortLevel {
  LOW
  MEDIUM
  HIGH
}

// === STRATEGIC: Partner-rubric-driven scoring (v1.3 per 17_unified_rubric.md) ===
model PartnerRubric {
  id          String  @id @default(cuid())
  partnerName String
  version     String
  description String?

  weights          Json
  stageOverrides   Json
  hardFailCriteria Json

  // Catalog patterns this rubric over-/under-weights (key → multiplier map).
  // Example: { feature_not_company: 1.5, vanity_traction: 1.4 }
  antiPatternsEmphasized   Json
  antiPatternsDeEmphasized Json

  // Patterns specific to this partner that aren't in the shared 16-catalog.
  // Per 17_unified_rubric.md §7. Array of { key, name, severity, ... }.
  customAntiPatterns Json

  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  analysisRuns AnalysisRun[]

  @@unique([partnerName, version])
}

// === STRATEGIC: Partner voice for memo generation ===
model PartnerProfile {
  id              String   @id @default(cuid())
  partnerName     String
  version         String
  voiceSamples    String[]
  tonalMarkers    String[]
  bannedPhrases   String[]
  signatureOpens  String[]
  signatureCloses String[]
  createdAt       DateTime @default(now())

  analysisRuns AnalysisRun[]

  @@unique([partnerName, version])
}

model Project {
  id              String            @id @default(cuid())
  companyName     String
  websiteUrl      String?
  oneLine         String?
  stage           FundingStage      @default(UNKNOWN)
  sector          String?
  businessModel   BusinessModel     @default(OTHER)
  targetRound     String?
  targetArchetype InvestorArchetype @default(GENERALIST_SEED)
  reviewerNotes   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  decks        Deck[]
  analysisRuns AnalysisRun[]
}

model Deck {
  id            String    @id @default(cuid())
  projectId     String
  fileName      String
  fileType      String
  fileSizeBytes Int
  storageKey    String
  checksum      String // SHA-256 — supports re-upload dedup
  pageCount     Int?
  uploadedAt    DateTime  @default(now())
  deletedAt     DateTime?

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analysisRuns AnalysisRun[]

  @@index([projectId])
  @@index([checksum])
}

model AnalysisRun {
  id                    String         @id @default(cuid())
  projectId             String
  deckId                String
  // STRATEGIC: every run is rubric+profile-stamped
  partnerRubricId       String
  partnerProfileId      String
  rubricVersion         String
  partnerProfileVersion String
  status                AnalysisStatus @default(QUEUED)
  stage                 AnalysisStage  @default(QUEUED)
  progress              Int            @default(0)
  errorMessage          String?
  modelProvider         String?
  modelName             String?
  promptVersion         String         @default("v0.2")
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  extractionJson   Json?
  resultJson       Json?
  providerMetaJson Json?

  project               Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deck                  Deck                   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  partnerRubric         PartnerRubric          @relation(fields: [partnerRubricId], references: [id])
  partnerProfile        PartnerProfile         @relation(fields: [partnerProfileId], references: [id])
  report                Report?
  slideReviews          SlideReview[]
  recommendations       Recommendation[]
  objections            InvestorObjection[]
  diligence             DiligenceItem[]
  antiPatternDetections AntiPatternDetection[]

  @@index([projectId])
  @@index([deckId])
  @@index([status])
}

model Report {
  id                         String            @id @default(cuid())
  analysisRunId              String            @unique
  fundabilityScore           Int
  meetingLikelihood          MeetingLikelihood
  meetingLikelihoodRationale String
  executiveSummary           String
  oneMinutePitch             String
  whatWouldNeedToBeTrue      String[]
  topStrengths               Json
  topPassReasons             Json
  keyMetrics                 Json
  riskSummary                Json
  memoJson                   Json
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model SlideReview {
  id                  String   @id @default(cuid())
  analysisRunId       String
  slideNumber         Int
  inferredTitle       String?
  slidePurpose        String?
  clarityScore        Int
  evidenceScore       Int
  investorImpactScore Int
  whatWorks           String[]
  issues              String[]
  rewriteGuidance     String
  suggestedTitle      String?
  evidenceToAdd       String[]
  // STRATEGIC: per-claim citation
  sourceQuote         String?
  expectedScoreDelta  Int      @default(0)
  rawJson             Json?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@unique([analysisRunId, slideNumber])
  @@index([analysisRunId])
}

model Recommendation {
  id                 String      @id @default(cuid())
  analysisRunId      String
  title              String
  problem            String
  recommendation     String
  investorRationale  String
  expectedImpact     ImpactLevel
  effort             EffortLevel
  priority           Priority
  expectedScoreDelta Int         @default(0)
  slideNumber        Int?
  exampleCopy        String?
  rawJson            Json?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId])
  @@index([priority])
}

model InvestorObjection {
  id               String      @id @default(cuid())
  analysisRunId    String
  // STRATEGIC: anti-pattern type from the named library
  antiPatternKey   String?
  title            String
  severity         ImpactLevel
  objection        String // partner-voiced quote
  whyItMatters     String
  howToAddress     String
  evidenceRequired String[]
  relatedSlide     Int?
  sourceQuote      String?
  rawJson          Json?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId])
  @@index([antiPatternKey])
}

model DiligenceItem {
  id                String   @id @default(cuid())
  analysisRunId     String
  category          String
  request           String
  whyItMatters      String
  suggestedEvidence String
  ownerRole         String?
  priority          Priority
  rawJson           Json?

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId])
}

// STRATEGIC: anti-pattern library — named, repeatable diagnostics
model AntiPatternDetection {
  id             String      @id @default(cuid())
  analysisRunId  String
  antiPatternKey String // FK to lib/ai/anti-patterns.ts catalog
  severity       ImpactLevel
  evidence       String // verbatim slide content that triggered detection
  slideNumber    Int?
  detectedAt     DateTime    @default(now())

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId])
  @@index([antiPatternKey])
}
